# MAX bot
SEND_MODE=max
MAX_BOT_TOKEN=your_max_bot_token
MAX_CHAT_ID=123456789
# Если MAX_CHAT_ID не задан или 0 — берётся из соседней папки ../yandex_sheets_max_bot/.env (удобно один чат на два бота).
MAX_SSL_VERIFY=true
# Optional first line in MAX for УПД commands (short body). Empty = omit (default).
# UPD_MESSAGE_BRAND=

# Google Sheets — JSON key (скачать в Google Cloud, включить Google Sheets API), не коммитить
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
# id из URL: https://docs.google.com/spreadsheets/d/<id>/edit
GOOGLE_SPREADSHEET_ID=1FtaQnep10k2yHW7krpVmB4uyMTn450ewmdVbXtgHyOM
# Необязательно: gid из URL (одна вкладка). Пример: ...edit?gid=123456789
# GOOGLE_SHEET_GID=
# Пусто при использовании GOOGLE_SHEET_GID. Или имя листа; иначе — все листы «Январь»…«Декабрь», иначе первый лист.
# TABLE_SHEET_NAME=
TABLE_COMMAND_COLUMN=Бухгалтеру в чат

# Polling
POLL_INTERVAL_SECONDS=60
TABLE_LOAD_TIMEOUT_SECONDS=180
RETRY_ATTEMPTS=2
RETRY_DELAY_SECONDS=2

# Storage (отдельный файл от яндекс-бота, если оба на одной машине)
DATABASE_PATH=data/google_accounting_max_bot.db
# BOOTSTRAP_SEND_MAX=false
# TABLE_COMMAND_SEND_EVERY_POLL=false
# DEDUP_STATUS_INFO_INTERVAL_SECONDS=600
